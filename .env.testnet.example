# Testnet scenario config (used by scripts/testnet/* and optional curl demos).
#
#   make testnet-env     # copies this file to .env.testnet
#   # Edit CONTRACT_ID — deploy the contract yourself (Stellar CLI, Lab, etc.)

API_URL=http://127.0.0.1:8080
NETWORK=testnet

# Required for automated scenarios and UI demos:
CONTRACT_ID=

# Optional — lookup by wasm (scenario S10); omit if you only use the UI:
DEPLOYED_WASM_HASH=

# Optional — GitHub scenario S09 (repo must match source you verified):
GITHUB_URL=
GIT_REF=

# Sample tarball paths (defaults work after make testnet-samples):
TARBALL_MATCH=examples/hello-world-source.tar.gz
TARBALL_MISMATCH=examples/mismatch-sample-source.tar.gz
TARBALL_INVALID=examples/invalid-source.tar.gz
